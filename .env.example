NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# App origin for invite links, password reset, etc. Must match Supabase Auth → Redirect URLs
# (add …/auth/reset-password for each origin you use, e.g. http://192.168.1.212:3001/auth/reset-password).
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=

# Dev only (Next.js .env.local — NOT the Supabase SQL editor): show recovery URL on /forgot-password.
# Never set in production. Requires SUPABASE_SERVICE_ROLE_KEY.
# DEV_SHOW_PASSWORD_RESET_LINK=true

# Backblaze B2 (S3-compatible). B2_BUCKET_ID is optional (console / scripts only).
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=
B2_ENDPOINT=
# Public URL prefix for uploaded objects (bucket must be readable if using URL with OpenAI Vision).
# Example: https://s3.us-west-004.backblazeb2.com/your-bucket-name
B2_PUBLIC_URL_BASE=

# OPENAI_API_KEY — already used by the app; set in .env.local (do not duplicate keys).

# Resend (server-side invoice email sending).
RESEND_API_KEY=
# Must be a verified sender/domain in Resend, e.g. invoices@yourdomain.com
RESEND_FROM_EMAIL=
# Optional reply-to mailbox
RESEND_REPLY_TO_EMAIL=

# Optional: Postgres enum label for new quotes when the DB has no default on quotes.status.
# Must match an existing value on your quote_status enum (see Supabase → SQL for enum labels).
# QUOTE_INSERT_STATUS=sent
